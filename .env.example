# RAKSHAK Environment Configuration

# -----------------------------------------------------------------------------
# Live Webhook Integration (For Evaluation/Judges)
# -----------------------------------------------------------------------------
# The response connectors in `backend/app/response/connectors.py` operate
# as mock stubs by default to prevent accidental modifications to infrastructure.
# To demonstrate LIVE REST API integrations during evaluation:
# 
# 1. Go to https://webhook.site/ (or similar webhook listener).
# 2. Copy your unique URL.
# 3. Paste it below for the respective connectors.
# 4. Trigger an action in the UI, and watch the JSON payload hit your webhook live!

# EDR API Endpoint (e.g., CrowdStrike Falcon containment)
RAKSHAK_EDR_API_URL=https://webhook.site/your-unique-uuid-here

# Firewall API Endpoint (e.g., Palo Alto block IP)
RAKSHAK_FIREWALL_API_URL=https://webhook.site/your-unique-uuid-here

# SOAR/Ticketing API Endpoint (e.g., JIRA incident creation)
RAKSHAK_TICKETING_API_URL=https://webhook.site/your-unique-uuid-here

# Required authorization token to execute API actions (Security hard-stop)
RAKSHAK_RESPONSE_API_TOKEN=demo-token

# -----------------------------------------------------------------------------
# Streaming Integration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
RAKSHAK_API_URL=http://localhost:8000
